<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — dark green casino feel -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#080e08</item>
        <item name="colorPrimaryDark">#050d05</item>
        <item name="colorAccent">#c9a84c</item>
        <item name="android:windowBackground">#080e08</item>
        <item name="android:statusBarColor">#080e08</item>
        <item name="android:navigationBarColor">#080e08</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#080e08</item>
        <item name="colorPrimaryDark">#050d05</item>
        <item name="colorAccent">#c9a84c</item>
        <item name="android:windowBackground">#080e08</item>
        <item name="android:statusBarColor">#080e08</item>
        <item name="android:navigationBarColor">#080e08</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowBackground">#080e08</item>
        <item name="windowSplashScreenBackground">#080e08</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

</resources>
