<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ── App Identity ── -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>Baccarat Gladiator</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- ── Platform ── -->
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>

	<!-- ── Orientation — portrait-primary on iPhone, all on iPad ── -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- ── UI ── -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>
	<key>UIStatusBarHidden</key>
	<false/>

	<!-- ── App Transport Security — allow baccaratgladiator.com assets ── -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>baccaratgladiator.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
			<key>googleapis.com</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
			<key>cognito-idp.us-east-1.amazonaws.com</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<false/>
			</dict>
		</dict>
	</dict>

	<!-- ── Privacy — no camera/mic/location needed ── -->
	<!-- Required by App Store even if not used, to avoid rejection -->
	<key>NSCameraUsageDescription</key>
	<string>Baccarat Gladiator does not use the camera.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Baccarat Gladiator does not use the microphone.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Baccarat Gladiator does not access your photo library.</string>

	<!-- ── Simulated Gambling Declaration ── -->
	<!-- Content rating: Frequent/Intense Simulated Gambling — 17+ -->
	<!-- No real money, no prizes, entertainment only -->

	<!-- ── Face ID / Biometrics ── -->
	<key>NSFaceIDUsageDescription</key>
	<string>Used for quick account sign-in.</string>

	<!-- ── Background modes — audio for game sounds ── -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>

	<!-- ── Capacitor internal ── -->
	<key>WKAppBoundDomains</key>
	<array>
		<string>baccaratgladiator.com</string>
	</array>
</dict>
</plist>
